---
export const prerender = true;

import Layout from '@/layouts/Layout.astro';
import { createSeo } from '@acomp/layout/seo.schema';
import BlogCard from '@acomp/playground/blog/BlogCard.astro';
import { getCollection, render } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort((a, b) => {
  if (!a.data.date || !b.data.date) return 0;
  return b.data.date.valueOf() - a.data.date.valueOf();
});
// get reading time for each post
const postsWithMeta = await Promise.all(
  posts.map(async (post) => {
    const { remarkPluginFrontmatter } = await render(post);
    const minutesRead: string = remarkPluginFrontmatter?.minutesRead;
    return { post, readingTime: minutesRead };
  })
);

const seo = createSeo({
  title: 'Blog',
  description: 'Latest posts from Fast Web Tech',
  date: new Date(2026, 3, 15).toISOString(),
  type: 'article',
});
---

<Layout {...seo}>
  <div slot="main" class="mx-auto max-w-4xl px-8 py-16">
    <h1 class="font-heading mb-12 text-5xl font-bold">Blog</h1>

    {postsWithMeta.length === 0 && <p class="text-muted-foreground">No posts yet.</p>}

    <div class="flex flex-col gap-10">
      {postsWithMeta.map(({ post, readingTime }) => <BlogCard post={post} readingTime={readingTime} />)}
    </div>
  </div>
</Layout>
