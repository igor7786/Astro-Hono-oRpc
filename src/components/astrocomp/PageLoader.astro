---
interface Props {
  delay?: number;
  componentCount?: number;
}
const { delay = 300, componentCount = 1 } = Astro.props;
---

<div
  id="page-loader"
  class="bg-background pointer-events-none fixed inset-0 z-50 flex items-center justify-center opacity-0 transition-opacity duration-300"
>
  <div class="border-muted border-t-foreground h-10 w-10 animate-spin rounded-full border-4"></div>
</div>

<script define:vars={{ delay, componentCount }}>
  const loader = document.getElementById('page-loader');
  if (!loader) throw new Error('PageLoader: #page-loader not found');

  let visible = false;
  let readyCount = 0;

  const timeout = setTimeout(() => {
    visible = true;
    loader.style.opacity = '1';
    loader.style.pointerEvents = 'auto';
  }, delay);

  function dismissLoader() {
    clearTimeout(timeout);
    if (visible) {
      loader.style.opacity = '0';
      setTimeout(() => loader.remove(), 300);
    } else {
      loader.remove();
    }
  }

  window.addEventListener('astro:component-ready', () => {
    readyCount++;
    if (readyCount >= componentCount) dismissLoader();
  });

  setTimeout(dismissLoader, 5000);
</script>
