---
import SEO from '@acomp/layout/SEO.astro';
import FONTS from '@acomp/layout/FONTS.astro';
import type { SEO as SEOType } from '@/lib/shared/schemas/seo.schema';
import themeScript from '@/scripts/theme-checker.js?raw';
import '@/styles/global.css';
const props = Astro.props as Partial<SEOType>;
---

<head>
  <!-- ✅ SEO -->
  <SEO {...props} />

  <!-- ✅ font preloads -->
  <FONTS />

  <!-- ✅ theme -->
  <script is:inline set:html={themeScript} />

  <!-- ✅ bones registry, auto-generated -->
  <script>
    import '@/bones/registry.js';
  </script>
</head>
