---
import SEO from '@acomp/SEO.astro';
import DevTools from '@/lib/tanstack-query/QueryDevTools';
import themeScript from '@/scripts/theme-checker.js?raw';
import '@/styles/global.css';
import { Toaster } from '@rcomp/ui/sonner';

interface Props {
  title?: string;
  description?: string;
  author?: string;
  date?: string;
  type?: string;
}

const { title, description, author, date, type } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <SEO title={title} description={description} author={author} date={date} type={type} />
    <script set:html={themeScript} />
  </head>
  <body>
    <div class="bg-background min-h-screen">
      <slot name="header" />
      <slot name="main" />
      <slot name="footer" />
      <Toaster client:load position="top-right" />
    </div>
    <DevTools client:only="react" />
  </body>
</html>
