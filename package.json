{
  "name": "astro-template",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "bun:dev": "bunx --bun astro dev --host",
    "bun:build": "bunx --bun astro build",
    "bun:preview": "bun run --bun  ./dist/server/entry.mjs",
    "ts:check": "astro check && bunx tsc --noEmit --incremental --tsBuildInfoFile ./node_modules/.cache/tsbuildinfo",
    "format": "bunx prettier --write \"./**/*.{ts,tsx,js,jsx,json,css,scss,md,astro,html,mjs}\"",
    "og:test": "bun run src/lib/server/seo/og/test-simple-og.ts",
    "knip": "knip --no-exit-code",
    "knip:fix": "knip --fix --no-exit-code",
    "husky:init": "bunx husky init",
    "prepare": "husky",
    "generate:contract": "bun run src/server/contracts/helpers/generate-contract-json.ts"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,astro,json,css,scss,md,html}": [
      "bunx prettier --write"
    ]
  },
  "dependencies": {
    "@astrojs/react": "5.0.4",
    "@astrojs/sitemap": "^3.7.2",
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "@nanostores/persistent": "^1.3.3",
    "@nanostores/react": "^1.1.0",
    "@orpc/client": "^1.13.9",
    "@orpc/json-schema": "^1.13.9",
    "@orpc/openapi": "^1.13.9",
    "@orpc/openapi-client": "^1.13.13",
    "@orpc/server": "^1.13.9",
    "@orpc/tanstack-query": "^1.13.9",
    "@orpc/zod": "^1.13.8",
    "@scalar/hono-api-reference": "^0.10.6",
    "@scalar/openapi-to-markdown": "^0.5.1",
    "@tailwindcss/vite": "^4.2.2",
    "@takumi-rs/image-response": "^1.0.0",
    "@tanstack/query-async-storage-persister": "^5.94.5",
    "@tanstack/react-query": "^5.94.5",
    "@tanstack/react-query-persist-client": "^5.94.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wyattjoh/astro-bun-adapter": "^2.0.1",
    "add": "^2.0.6",
    "astro": "6.1.9",
    "boneyard-js": "^1.7.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.8",
    "idb-keyval": "^6.2.2",
    "ioredis": "^5.10.1",
    "lucide-react": "^1.8.0",
    "mdast-util-to-string": "^4.0.0",
    "nanostores": "^1.2.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reading-time": "^1.5.0",
    "satori": "^0.26.0",
    "shadcn": "^4.0.8",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query-devtools": "^5.94.5",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/bun": "^1.3.11",
    "husky": "^9.1.7",
    "knip": "^6.4.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-classnames": "^0.9.0",
    "prettier-plugin-merge": "^0.10.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^6.0.2"
  }
}
